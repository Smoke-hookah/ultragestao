API_URL=https://api.meudanfe.com.br/v2
API_KEY=sua_api_key_aqui
# Alternativa: múltiplas chaves (se definido, substitui API_KEY)
# API_KEYS=key1,key2,key3,key4,key5
LOG_LEVEL=INFO
DELAY_BETWEEN_REQUESTS=1.5
MAX_REQUESTS_PER_SECOND=1

# (Opcional) Throttle específico para PUT (uploads)
# Se não setar, usa os valores globais acima.
PUT_DELAY_BETWEEN_REQUESTS=0
PUT_MAX_REQUESTS_PER_SECOND=5

# (Opcional) Throttle específico para GET (downloads)
# Se não setar, usa os valores globais acima.
GET_DELAY_BETWEEN_REQUESTS=0.2
GET_MAX_REQUESTS_PER_SECOND=5

# (Recomendado) Estabilidade do GET logo após PUT
# Algumas NFs podem levar alguns segundos para aparecer na área do cliente.
POST_PUT_WAIT_SECONDS=5
GET_RETRY_ROUNDS=6
GET_RETRY_BASE_DELAY_SECONDS=1
GET_RETRY_MAX_DELAY_SECONDS=15

# Migração do histórico de PUT: quando o histórico antigo não tem Api-Key associada,
# tenta descobrir qual Api-Key possui a NF na "Área do Cliente" (1 GET por key) e grava no histórico.
# Recomendado quando você usa múltiplas API_KEYS.
MIGRATE_HISTORY_API_KEY=1

# Upload via Frontend (multipart)
# Se você enviar muitos XMLs de uma vez, pode estourar limite do servidor (413).
MAX_UPLOAD_MB=2048
MAX_FORM_PARTS=20000

# (Opcional) Permite rodar em modo local (teste) sem API_KEY/API_KEYS.
# Use em conjunto com metodo_pdf=local.
# ALLOW_NO_API_KEYS=1

# Ajuste do gerador local para lotes grandes de XML -> PDF.
# auto usa process pool em lotes maiores e thread pool nos menores.
# LOCAL_PDF_EXECUTOR=auto
# LOCAL_PDF_WORKERS=8

# No executavel standalone, o app sobe sem API_KEY por padrao.
# Coloque este .env ao lado do .exe apenas quando quiser usar a API Meu Danfe.
